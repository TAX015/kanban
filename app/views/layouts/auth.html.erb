<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Kanban Login" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# Use flexbox to center the login form perfectly on the screen %>
  <body class="dark:bg-gray-900 dark:text-white flex items-center justify-center min-h-screen bg-gray-50">
    <main class="w-full max-w-md p-4">
      <%= yield %>
    </main>
  </body>
</html>